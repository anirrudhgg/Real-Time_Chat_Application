from flask import Flask, request, jsonify, render_template_string
from datetime import datetime, timedelta

app = Flask(__name__)

# list that stores all messages
messages = []

page = """
<!DOCTYPE html>
<html>
<head>
    <title>Disappearing Messages</title>

    <style>

        body{
            font-family: Arial, sans-serif;
            background-color:#f0f0f0;
            margin:0;
            padding:20px;
        }

        h1{
            text-align:center;
        }

        .chat{
            width:700px;
            margin:auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0px 0px 5px gray;
        }

        #messages{
            border:1px solid gray;
            height:350px;
            overflow-y:auto;
            padding:10px;
            margin-bottom:15px;
            background:#fafafa;
        }

        .msg{
            margin-bottom:10px;
            padding:8px;
            border-bottom:1px solid #ddd;
        }

        input, select{
            padding:8px;
            margin-right:5px;
        }

        button{
            padding:8px 15px;
            cursor:pointer;
        }

        .name{
            font-weight:bold;
        }

    </style>
</head>

<body>

<div class="chat">

    <h1>Disappearing Messages Chat</h1>

    <div id="messages"></div>

    <input type="text" id="name" placeholder="Your name">

    <input type="text" id="text" placeholder="Type a message">

    <select id="timer">
        <option value="10">10 Seconds</option>
        <option value="30">30 Seconds</option>
    </select>

    <button onclick="sendMessage()">Send</button>

</div>

<script>

function loadMessages(){

    fetch('/messages')
    .then(response => response.json())
    .then(data => {

        let box = document.getElementById("messages");

        box.innerHTML = "";

        data.forEach(function(msg){

            box.innerHTML += `
                <div class="msg">
                    <span class="name">${msg.name}</span>:
                    ${msg.text}
                    <br>
                    <small>
                        disappears in ${msg.left}s
                    </small>
                </div>
            `;
        });

    });

}

function sendMessage(){

    let name = document.getElementById("name").value;
    let text = document.getElementById("text").value;
    let timer = document.getElementById("timer").value;

    if(name == "" || text == ""){
        alert("Please fill all fields");
        return;
    }

    fetch('/send', {

        method:'POST',

        headers:{
            'Content-Type':'application/json'
        },

        body:JSON.stringify({
            name:name,
            text:text,
            timer:timer
        })

    })
    .then(() => {

        document.getElementById("text").value = "";

        loadMessages();
    });

}

setInterval(loadMessages,1000);

loadMessages();

</script>

</body>
</html>
"""


@app.route("/")
def home():
    return render_template_string(page)


@app.route("/send", methods=["POST"])
def send():

    data = request.get_json()

    name = data["name"]
    text = data["text"]
    timer = int(data["timer"])

    expire = datetime.now() + timedelta(seconds=timer)

    messages.append({
        "name": name,
        "text": text,
        "expire": expire
    })

    return jsonify({"message":"saved"})


@app.route("/messages")
def get_messages():

    now = datetime.now()

    messages[:] = [
        m for m in messages
        if m["expire"] > now
    ]

    result = []

    for m in messages:

        left = int(
            (m["expire"] - now).total_seconds()
        )

        result.append({
            "name": m["name"],
            "text": m["text"],
            "left": left
        })

    return jsonify(result)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8080, debug=True)
